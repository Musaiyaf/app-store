{ "name":"Street Hustle", "version":"1.0", "author":"musaiyaf", "desc":"Risk vs reward heist game. Pick jobs, dodge heat, cash out before you get busted.", "script":"print('=== STREET HUSTLE ===');\ndelay(400);\nprint('Pick your jobs. Bigger scores,');\nprint('bigger heat. Get busted, lose it all.');\ndelay(600);\n\nvar cash = 0;\nvar heat = 0;\nvar busted = false;\n\nvar jobs = [\n  { name: 'Corner Store',  risk: 0.05, pay: 50  },\n  { name: 'Gas Station',   risk: 0.12, pay: 120 },\n  { name: 'Jewelry Store', risk: 0.22, pay: 300 },\n  { name: 'Bank Vault',    risk: 0.35, pay: 800 }\n];\n\nfor (var round = 1; round <= 5; round++) {\n  print('');\n  print('--- Round ' + round + ' ---');\n  print('Cash: $' + cash + '  Heat: ' + heat + '%');\n  delay(500);\n\n  // auto-pick a job, escalating with heat\n  var pick = Math.min(jobs.length - 1, Math.floor(heat / 30));\n  var job = jobs[pick];\n\n  print('Job: ' + job.name);\n  delay(400);\n  print('Hitting it...');\n  delay(800);\n\n  var roll = Math.random();\n  var bustChance = job.risk + (heat / 400);\n\n  if (roll < bustChance) {\n    print('SIRENS! You got busted.');\n    busted = true;\n    cash = 0;\n    break;\n  } else {\n    cash += job.pay;\n    heat += Math.floor(job.risk * 40);\n    if (heat > 100) heat = 100;\n    print('Score! +$' + job.pay);\n  }\n  delay(700);\n}\n\nprint('');\nprint('=== RESULT ===');\nif (busted) {\n  print('Busted. Walked away with $0.');\n} else {\n  print('Got away clean.');\n  print('Total take: $' + cash);\n}" }
