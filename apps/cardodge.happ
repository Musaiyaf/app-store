{"name": "Car Dodge", "version": "1.1", "author": "Musaiyaf", "desc": "Dodge traffic! LFT/RHT steer", "script": "var d = require(\"display\");\nvar kb = require(\"keyboard\");\nvar math = require(\"math\");\n\n// ── Screen & lane setup ──────────────────────────────\nvar W = d.width();   // 240\nvar H = d.height();  // 240\n\nvar LANES = [30, 80, 130, 180];  // 4 lane X centres\nvar CAR_W = 28;\nvar CAR_H = 48;\n\n// ── Colors ───────────────────────────────────────────\nvar C_BG       = d.color565(10, 10, 20);\nvar C_ROAD     = d.color565(30, 30, 40);\nvar C_LANE     = d.color565(60, 60, 70);\nvar C_WHITE    = d.color565(255, 255, 255);\nvar C_YELLOW   = d.color565(255, 220, 0);\nvar C_RED      = d.color565(220, 40, 40);\nvar C_GREEN    = d.color565(40, 200, 80);\nvar C_BLUE     = d.color565(40, 120, 255);\nvar C_CYAN     = d.color565(0, 220, 220);\nvar C_ORANGE   = d.color565(255, 140, 0);\nvar C_PURPLE   = d.color565(180, 60, 220);\nvar C_PLAYER   = d.color565(0, 200, 255);\nvar C_DARK     = d.color565(5, 5, 15);\nvar C_GRAY     = d.color565(80, 80, 90);\nvar C_SCORE    = d.color565(255, 230, 100);\nvar C_CRASH    = d.color565(255, 80, 0);\n\nvar ENEMY_COLORS = [C_RED, C_GREEN, C_YELLOW, C_ORANGE, C_PURPLE, C_CYAN];\n\n// ── Draw a car (top-down view) ────────────────────────\n// cx=centre x, ty=top y, color, isPlayer\nfunction drawCar(cx, ty, color, isPlayer) {\n  var x = cx - CAR_W / 2;\n  // Body\n  d.fill(x + 3, ty + 4, CAR_W - 6, CAR_H - 8, color);\n  // Roof/cabin\n  var roofC = isPlayer ? d.color565(0, 100, 140) : d.color565(20, 20, 20);\n  d.fill(x + 6, ty + 12, CAR_W - 12, CAR_H - 26, roofC);\n  // Front windshield\n  d.fill(x + 5, ty + 8, CAR_W - 10, 6, d.color565(150, 220, 255));\n  // Rear windshield\n  d.fill(x + 5, ty + CAR_H - 16, CAR_W - 10, 5, d.color565(120, 180, 200));\n  // Wheels (4 corners)\n  var wc = d.color565(20, 20, 20);\n  d.fill(x,             ty + 4,          5, 10, wc);\n  d.fill(x + CAR_W - 5, ty + 4,          5, 10, wc);\n  d.fill(x,             ty + CAR_H - 14, 5, 10, wc);\n  d.fill(x + CAR_W - 5, ty + CAR_H - 14, 5, 10, wc);\n  // Headlights / taillights\n  if (isPlayer) {\n    // headlights (top of player car)\n    d.fill(x + 4,        ty + 2, 6, 4, C_WHITE);\n    d.fill(x + CAR_W-10, ty + 2, 6, 4, C_WHITE);\n    // taillights\n    d.fill(x + 4,        ty + CAR_H - 6, 6, 4, C_RED);\n    d.fill(x + CAR_W-10, ty + CAR_H - 6, 6, 4, C_RED);\n  } else {\n    // enemy: headlights at bottom (coming toward you)\n    d.fill(x + 4,        ty + CAR_H - 6, 6, 4, C_YELLOW);\n    d.fill(x + CAR_W-10, ty + CAR_H - 6, 6, 4, C_YELLOW);\n    // taillights at top\n    d.fill(x + 4,        ty + 2, 6, 4, C_RED);\n    d.fill(x + CAR_W-10, ty + 2, 6, 4, C_RED);\n  }\n}\n\n// ── Draw road with lane markings ─────────────────────\nvar dashOffset = 0;\nfunction drawRoad() {\n  // Background\n  d.fill(0, 0, W, H, C_BG);\n  // Road surface\n  d.fill(10, 0, W - 20, H, C_ROAD);\n  // Kerbs\n  d.fill(0,     0, 10, H, C_GRAY);\n  d.fill(W - 10, 0, 10, H, C_GRAY);\n  // Lane dividers (dashed, animated)\n  var laneXs = [55, 105, 155];\n  for (var li = 0; li < 3; li++) {\n    var lx = laneXs[li];\n    for (var dy = 0; dy < H + 20; dy += 30) {\n      var yy = (dy - dashOffset) % (H + 30) - 10;\n      d.fill(lx - 1, yy, 2, 14, C_LANE);\n    }\n  }\n}\n\n// ── Erase a car (paint over with road) ───────────────\nfunction eraseCar(cx, ty) {\n  var x = cx - CAR_W / 2 - 1;\n  // Redraw road section behind car\n  d.fill(x < 10 ? 10 : x, ty, CAR_W + 2, CAR_H + 1, C_ROAD);\n  // Re-draw any lane dividers that crossed this area\n  var laneXs = [55, 105, 155];\n  for (var li = 0; li < 3; li++) {\n    var lx = laneXs[li];\n    if (lx >= x && lx <= x + CAR_W + 2) {\n      for (var dy = 0; dy < H + 20; dy += 30) {\n        var yy = (dy - dashOffset) % (H + 30) - 10;\n        if (yy + 14 >= ty && yy <= ty + CAR_H + 1) {\n          d.fill(lx - 1, yy < ty ? ty : yy, 2,\n            (yy + 14 > ty + CAR_H + 1 ? ty + CAR_H + 1 : yy + 14) - (yy < ty ? ty : yy), C_LANE);\n        }\n      }\n    }\n  }\n}\n\n// ── HUD ──────────────────────────────────────────────\nfunction drawHUD(score, lives) {\n  // Score bar at top\n  d.fill(0, 0, W, 10, C_DARK);\n  d.print(\"SCORE:\" + score, 4, 1, 1, C_SCORE);\n  // Lives as small colored dots\n  for (var i = 0; i < lives; i++) {\n    d.fill(W - 12 - i * 12, 2, 8, 6, C_PLAYER);\n  }\n}\n\n// ── Explosion flash ───────────────────────────────────\nfunction drawExplosion(cx, cy) {\n  for (var r = 5; r <= 28; r += 6) {\n    d.circle(cx, cy, r, C_CRASH, false);\n    delay(30);\n  }\n  for (var r2 = 28; r2 >= 5; r2 -= 6) {\n    d.circle(cx, cy, r2, C_BG, false);\n    delay(20);\n  }\n}\n\n// ── Title screen ─────────────────────────────────────\nfunction drawTitle() {\n  d.clear();\n  d.fill(0, 0, W, H, C_BG);\n  // Road preview\n  d.fill(10, 0, W - 20, H, C_ROAD);\n  d.fill(0,     0, 10, H, C_GRAY);\n  d.fill(W-10,  0, 10, H, C_GRAY);\n  // Title box\n  d.fill(20, 60, 200, 50, d.color565(0, 40, 80));\n  d.fill(22, 62, 196, 46, d.color565(0, 20, 50));\n  d.print(\"  CAR DODGE\", 28, 72, 2, C_PLAYER);\n  d.print(\"  HandyOS v1\", 30, 96, 1, C_CYAN);\n  // Sample cars\n  drawCar(LANES[1], 130, C_RED, false);\n  drawCar(LANES[2], 130, C_GREEN, false);\n  drawCar(LANES[1] + 50, 30, C_PLAYER, true);\n  // Instructions\n  d.fill(15, 185, 210, 46, d.color565(5, 5, 20));\n  d.print(\"LFT/RHT = steer\", 22, 192, 1, C_WHITE);\n  d.print(\"Dodge the traffic!\", 22, 204, 1, C_YELLOW);\n  d.print(\"  MID = START\", 30, 218, 1, C_GREEN);\n  // Wait for MID\n  while (true) {\n    var b = kb.getButton();\n    if (b === \"MID\") break;\n    delay(10);\n  }\n}\n\n// ── Game Over screen ──────────────────────────────────\nfunction drawGameOver(score) {\n  delay(400);\n  d.fill(25, 80, 190, 90, C_DARK);\n  d.fill(27, 82, 186, 86, d.color565(60, 0, 0));\n  d.print(\" GAME OVER\", 35, 92, 2, C_CRASH);\n  d.print(\"Score: \" + score, 70, 120, 1, C_SCORE);\n  d.print(\"MID=Play Again\", 40, 140, 1, C_WHITE);\n  d.print(\"RST=Quit\", 72, 154, 1, C_GRAY);\n  while (true) {\n    var b = kb.getButton();\n    if (b === \"MID\") return true;\n    if (b === \"RST\") return false;\n    delay(10);\n  }\n}\n\n// ── Main game loop ────────────────────────────────────\nfunction runGame() {\n  // ── State ──\n  var playerLane = 1;            // 0-3\n  var playerY = H - CAR_H - 12;\n\n  // Enemies: up to 4 on screen\n  var eActive = [false, false, false, false];\n  var eLane   = [0, 1, 2, 3];\n  var eY      = [-CAR_H, -CAR_H, -CAR_H, -CAR_H];\n  var eColor  = [C_RED, C_GREEN, C_ORANGE, C_PURPLE];\n  var eSpeed  = [0, 0, 0, 0];\n\n  var score       = 0;\n  var lives       = 3;\n  var speed       = 2.5;\n  var dashSpd     = 2;\n  var spawnTimer  = 0;\n  var spawnRate   = 60;   // frames between spawns\n  var frameCount  = 0;\n  var lastTime    = millis();\n\n  // Draw initial road\n  drawRoad();\n  drawCar(LANES[playerLane], playerY, C_PLAYER, true);\n  drawHUD(score, lives);\n\n  while (lives > 0) {\n    var now = millis();\n    var dt = now - lastTime;\n    if (dt < 16) { delay(16 - dt); continue; }\n    lastTime = millis();\n    frameCount++;\n\n    // ── Input ──────────────────────────────────────\n    var btn = kb.getButton();\n    var prevLane = playerLane;\n    if (btn === \"LFT\" && playerLane > 0) playerLane--;\n    if (btn === \"RHT\" && playerLane < 3) playerLane++;\n    if (btn === \"RST\") break;\n\n    // ── Speed ramp (every 200 frames) ──────────────\n    if (frameCount % 200 === 0) {\n      speed += 0.3;\n      dashSpd += 0.2;\n      if (spawnRate > 25) spawnRate -= 3;\n    }\n\n    // ── Spawn enemy ────────────────────────────────\n    spawnTimer++;\n    if (spawnTimer >= spawnRate) {\n      spawnTimer = 0;\n      // Pick a free slot\n      for (var si = 0; si < 4; si++) {\n        if (!eActive[si]) {\n          // Pick a random lane (avoid player lane if possible)\n          var tries = 0;\n          var lane;\n          do {\n            lane = math.floor(random(0, 4));\n            tries++;\n          } while (lane === playerLane && tries < 5);\n          eActive[si] = true;\n          eLane[si]   = lane;\n          eY[si]      = -CAR_H;\n          eColor[si]  = ENEMY_COLORS[math.floor(random(0, 6))];\n          eSpeed[si]  = speed + random(0, 10) / 10.0;\n          break;\n        }\n      }\n    }\n\n    // ── Erase player if moved ──────────────────────\n    if (prevLane !== playerLane) {\n      eraseCar(LANES[prevLane], playerY);\n    }\n\n    // ── Animate lane dashes ────────────────────────\n    dashOffset = (dashOffset + dashSpd) % 30;\n\n    // ── Move & draw enemies ────────────────────────\n    for (var ei = 0; ei < 4; ei++) {\n      if (!eActive[ei]) continue;\n      var prevY = math.floor(eY[ei]);\n      eY[ei] += eSpeed[ei];\n      var newY = math.floor(eY[ei]);\n\n      // Off screen — erase and deactivate, add score\n      if (newY > H) {\n        eraseCar(LANES[eLane[ei]], prevY);\n        eActive[ei] = false;\n        score += 10;\n        continue;\n      }\n\n      // Collision check\n      var ex = LANES[eLane[ei]];\n      var px = LANES[playerLane];\n      var horizOk = math.abs(ex - px) < (CAR_W - 4);\n      var vertOk  = newY + CAR_H > playerY + 4 && newY < playerY + CAR_H - 4;\n      if (horizOk && vertOk) {\n        // Crash!\n        drawExplosion(px, playerY + CAR_H / 2);\n        eActive[ei] = false;\n        lives--;\n        if (lives <= 0) break;\n        // Brief invincibility redraw\n        drawRoad();\n        drawCar(LANES[playerLane], playerY, C_PLAYER, true);\n        drawHUD(score, lives);\n        delay(600);\n        lastTime = millis();\n        continue;\n      }\n\n      // Erase old position, draw new\n      if (prevY !== newY) {\n        eraseCar(LANES[eLane[ei]], prevY);\n      }\n      drawCar(LANES[eLane[ei]], newY, eColor[ei], false);\n    }\n\n    // ── Redraw road lines & player ─────────────────\n    // Redraw lane dashes (cheap: just the dash strips)\n    var laneXs = [55, 105, 155];\n    for (var li = 0; li < 3; li++) {\n      var lx = laneXs[li];\n      for (var dy = 0; dy < H + 20; dy += 30) {\n        var yy = (dy - math.floor(dashOffset)) % (H + 30) - 10;\n        d.fill(lx - 1, yy > 10 ? yy : 10, 2, 14, C_LANE);\n      }\n    }\n\n    drawCar(LANES[playerLane], playerY, C_PLAYER, true);\n    drawHUD(score, lives);\n    delay(1); // feed WDT every frame\n  }\n\n  return score;\n}\n\n// ── Entry point ───────────────────────────────────────\ndrawTitle();\nwhile (true) {\n  var finalScore = runGame();\n  var again = drawGameOver(finalScore);\n  if (!again) break;\n}\nd.clear();\n"}