{
  "name": "SD Manager",
  "version": "1.0",
  "author": "musaiyaf",
  "desc": "Colourful SD card file manager",
  "script": "var C_BG     = display.color565(8,   8,  20);\nvar C_HDR    = display.color565(20,  20,  50);\nvar C_ACC    = display.color565(80, 180, 255);\nvar C_YLW    = display.color565(255, 220,  60);\nvar C_GRN    = display.color565( 80, 220, 120);\nvar C_RED    = display.color565(255,  80,  80);\nvar C_PRP    = display.color565(180, 100, 255);\nvar C_ORG    = display.color565(255, 160,  60);\nvar C_DIM    = display.color565( 90,  90, 120);\nvar C_TXT    = display.color565(220, 220, 240);\nvar C_SEL    = display.color565(20,  60, 120);\nvar C_SELBRD = display.color565(80, 180, 255);\n\nvar SW = hap.screenW;\nvar SH = hap.screenH;\nvar ROW_H   = 28;\nvar LIST_Y  = 48;\nvar FOOT_Y  = 218;\nvar MAX_VIS = 6;\n\nvar curPath  = \"/\";\nvar entries  = [];\nvar sel      = 0;\nvar scroll   = 0;\nvar mode     = \"browse\";\n\nfunction clamp(v, lo, hi) {\n  return v < lo ? lo : v > hi ? hi : v;\n}\n\nfunction sizeStr(bytes) {\n  if (bytes < 1024) return bytes + \"B\";\n  if (bytes < 1048576) return Math.floor(bytes / 1024) + \"KB\";\n  return Math.floor(bytes / 1048576) + \"MB\";\n}\n\nfunction shortName(name, maxChars) {\n  if (name.length <= maxChars) return name;\n  return name.substring(0, maxChars - 2) + \"..\";\n}\n\nfunction fileColor(name, isDir) {\n  if (isDir) return C_YLW;\n  var ext = name.lastIndexOf(\".\");\n  if (ext < 0) return C_TXT;\n  var e = name.substring(ext + 1).toLowerCase();\n  if (e === \"hap\" || e === \"happ\") return C_GRN;\n  if (e === \"js\")  return C_ORG;\n  if (e === \"txt\" || e === \"md\") return C_ACC;\n  if (e === \"jpg\" || e === \"png\" || e === \"bmp\") return C_PRP;\n  if (e === \"json\") return C_ORG;\n  if (e === \"csv\")  return C_GRN;\n  return C_TXT;\n}\n\nfunction loadDir(path) {\n  curPath = path;\n  sel = 0;\n  scroll = 0;\n  entries = [];\n  var files = storage.list(path);\n  if (!files) { files = []; }\n  var dirs = [];\n  var fils = [];\n  for (var i = 0; i < files.length; i++) {\n    var f = files[i];\n    if (f.isDirectory || f.isDir) dirs.push(f);\n    else fils.push(f);\n  }\n  if (curPath !== \"/\") {\n    entries.push({ name: \"..\", isDir: true, size: 0 });\n  }\n  for (var i = 0; i < dirs.length; i++) entries.push({ name: dirs[i].name, isDir: true,  size: 0 });\n  for (var i = 0; i < fils.length; i++) entries.push({ name: fils[i].name, isDir: false, size: fils[i].size || 0 });\n}\n\nfunction drawHeader() {\n  display.fill(0, 0, SW, 44, C_HDR);\n  display.fill(4, 4, 100, 16, display.color565(30, 30, 70));\n  display.print(6, 6, \"SD MANAGER\", C_ACC, 1);\n  var p = shortName(curPath, 28);\n  display.print(4, 26, p, C_DIM, 1);\n  var badge = entries.length + \" items\";\n  display.print(SW - 60, 26, badge, C_DIM, 1);\n  display.line(0, 44, SW, 44, C_ACC);\n}\n\nfunction drawFooter() {\n  display.line(0, FOOT_Y, SW, FOOT_Y, C_DIM);\n  display.fill(0, FOOT_Y + 1, SW, SH - FOOT_Y - 1, C_BG);\n  display.print(2, FOOT_Y + 3, \"MID=open  SET=del  RST=back\", C_DIM, 1);\n}\n\nfunction drawRow(i, y, isSel) {\n  var e = entries[i];\n  var bg = isSel ? C_SEL : C_BG;\n  display.fill(0, y, SW, ROW_H - 1, bg);\n  if (isSel) {\n    display.line(0, y, 0, y + ROW_H - 2, C_SELBRD);\n    display.line(SW - 1, y, SW - 1, y + ROW_H - 2, C_SELBRD);\n  }\n  var col = fileColor(e.name, e.isDir);\n  display.fill(2, y + 3, 3, ROW_H - 8, col);\n  var maxChars = e.isDir ? 22 : 18;\n  var label = shortName(e.name, maxChars);\n  display.print(10, y + 4, label, isSel ? C_TXT : col, 1);\n  if (!e.isDir && e.name !== \"..\") {\n    var sz = sizeStr(e.size);\n    display.print(SW - 34, y + 4, sz, C_DIM, 1);\n  }\n  if (e.isDir) {\n    display.print(SW - 14, y + 4, \">\", isSel ? C_ACC : C_DIM, 1);\n  }\n  display.line(8, y + ROW_H - 1, SW - 8, y + ROW_H - 1,\n               isSel ? display.color565(30, 60, 100) : display.color565(18, 18, 35));\n}\n\nfunction drawScrollbar() {\n  if (entries.length <= MAX_VIS) return;\n  var barH   = SH - LIST_Y - (SH - FOOT_Y);\n  var thumbH = Math.max(10, Math.floor(barH * MAX_VIS / entries.length));\n  var thumbY = LIST_Y + Math.floor((barH - thumbH) * scroll / (entries.length - MAX_VIS));\n  display.fill(SW - 3, LIST_Y, 3, barH, display.color565(20, 20, 40));\n  display.fill(SW - 3, thumbY, 3, thumbH, C_ACC);\n}\n\nfunction drawBrowse() {\n  display.clear(C_BG);\n  drawHeader();\n  if (entries.length === 0) {\n    display.print(20, LIST_Y + 40, \"Empty folder\", C_DIM, 1);\n  } else {\n    var visCount = Math.min(MAX_VIS, entries.length - scroll);\n    for (var i = 0; i < visCount; i++) {\n      var idx = scroll + i;\n      drawRow(idx, LIST_Y + i * ROW_H, idx === sel);\n    }\n    drawScrollbar();\n  }\n  drawFooter();\n}\n\nfunction drawConfirmDelete() {\n  var e = entries[sel];\n  display.fill(20, 70, SW - 40, 110, display.color565(5, 5, 15));\n  display.line(20, 70, SW - 20, 70, C_RED);\n  display.line(20, 180, SW - 20, 180, C_RED);\n  display.line(20, 70, 20, 180, C_RED);\n  display.line(SW-20, 70, SW-20, 180, C_RED);\n  display.print(30, 80, \"DELETE?\", C_RED, 1);\n  display.print(28, 96, shortName(e.name, 24), C_YLW, 1);\n  if (e.isDir) {\n    display.print(28, 112, \"(folder + contents)\", C_DIM, 1);\n  }\n  display.fill(30, 130, 80, 22, display.color565(120, 20, 20));\n  display.print(44, 136, \"DELETE\", C_TXT, 1);\n  display.fill(125, 130, 80, 22, display.color565(20, 60, 20));\n  display.print(143, 136, \"CANCEL\", C_TXT, 1);\n  display.print(28, 162, \"MID=confirm  RST=cancel\", C_DIM, 1);\n}\n\nfunction drawInfo() {\n  var e = entries[sel];\n  var fullPath = curPath === \"/\" ? \"/\" + e.name : curPath + \"/\" + e.name;\n  display.fill(10, 60, SW - 20, 140, display.color565(8, 8, 28));\n  display.line(10, 60, SW - 10, 60, C_PRP);\n  display.line(10, 60, 10, 200, C_PRP);\n  display.line(SW-10, 60, SW-10, 200, C_PRP);\n  display.line(10, 200, SW-10, 200, C_PRP);\n  display.print(18, 68, \"FILE INFO\", C_PRP, 1);\n  display.line(14, 80, SW - 16, 80, display.color565(40, 20, 60));\n  var col = fileColor(e.name, e.isDir);\n  display.print(18, 88,  \"Name:\", C_DIM, 1);\n  display.print(18, 100, shortName(e.name, 26), col, 1);\n  display.print(18, 116, \"Path:\", C_DIM, 1);\n  display.print(18, 128, shortName(fullPath, 26), C_ACC, 1);\n  display.print(18, 144, \"Type:\", C_DIM, 1);\n  display.print(18, 156, e.isDir ? \"Directory\" : \"File\", col, 1);\n  if (!e.isDir) {\n    display.print(18, 172, \"Size:\", C_DIM, 1);\n    display.print(18, 184, sizeStr(e.size), C_GRN, 1);\n  }\n  display.print(18, 194, \"RST=close\", C_DIM, 1);\n}\n\nfunction navigateInto() {\n  if (entries.length === 0) return;\n  var e = entries[sel];\n  if (e.name === \"..\") {\n    var parts = curPath.split(\"/\").filter(function(s){ return s.length > 0; });\n    parts.pop();\n    loadDir(parts.length === 0 ? \"/\" : \"/\" + parts.join(\"/\"));\n    drawBrowse();\n    return;\n  }\n  if (e.isDir) {\n    var newPath = curPath === \"/\" ? \"/\" + e.name : curPath + \"/\" + e.name;\n    loadDir(newPath);\n    drawBrowse();\n  } else {\n    mode = \"info\";\n    drawBrowse();\n    drawInfo();\n  }\n}\n\nfunction doDelete() {\n  if (entries.length === 0) return;\n  var e = entries[sel];\n  var fullPath = curPath === \"/\" ? \"/\" + e.name : curPath + \"/\" + e.name;\n  if (e.isDir) {\n    storage.rmrf(fullPath);\n  } else {\n    storage.remove(fullPath);\n  }\n  loadDir(curPath);\n  if (sel >= entries.length) sel = Math.max(0, entries.length - 1);\n  drawBrowse();\n}\n\nloadDir(\"/\");\ndrawBrowse();\n\neventLoop.subscribe(\"input\", function(e) {\n  var btn = e.key;\n  if (mode === \"confirm_delete\") {\n    if (btn === \"ok\" || btn === \"mid\") { mode = \"browse\"; doDelete(); }\n    else if (btn === \"back\" || btn === \"rst\") { mode = \"browse\"; drawBrowse(); }\n    return;\n  }\n  if (mode === \"info\") {\n    if (btn === \"back\" || btn === \"rst\") { mode = \"browse\"; drawBrowse(); }\n    return;\n  }\n  if (btn === \"up\") {\n    if (sel > 0) { sel--; if (sel < scroll) scroll = sel; drawBrowse(); }\n  } else if (btn === \"down\") {\n    if (sel < entries.length - 1) {\n      sel++;\n      if (sel >= scroll + MAX_VIS) scroll = sel - MAX_VIS + 1;\n      drawBrowse();\n    }\n  } else if (btn === \"ok\" || btn === \"mid\" || btn === \"right\") {\n    navigateInto();\n  } else if (btn === \"set\") {\n    if (entries.length > 0 && entries[sel].name !== \"..\") {\n      mode = \"confirm_delete\";\n      drawBrowse();\n      drawConfirmDelete();\n    }\n  } else if (btn === \"back\" || btn === \"rst\" || btn === \"left\") {\n    if (curPath === \"/\") { hap.exit(); }\n    else {\n      var parts = curPath.split(\"/\").filter(function(s){ return s.length > 0; });\n      parts.pop();\n      loadDir(parts.length === 0 ? \"/\" : \"/\" + parts.join(\"/\"));\n      drawBrowse();\n    }\n  }\n});\n\neventLoop.run();"
}